                  Show          off
                }
                Parameter {
                  Variable      "NumOutputs"
                  Value         "-1"
                  Show          off
                }
                Parameter {
                  Variable      "NumContStates"
                  Value         "0"
                  Show          off
                }
                Parameter {
                  Variable      "NumDiscStates"
                  Value         "-1"
                  Show          off
                }
                Parameter {
                  Variable      "NumZCSignals"
                  Value         "0"
                  Show          off
                }
                Parameter {
                  Variable      "DirectFeedthrough"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "Ts"
                  Value         "[1/fc carrier_phaseshift/fc; -2 0]"
                  Show          off
                }
                Parameter {
                  Variable      "TerminalBasedSampleTimes"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "Parameters"
                  Value         "fc, carrier_phaseshift, carrier_limits, outpu"
"t_values, update_peak"
                  Show          off
                }
                Parameter {
                  Variable      "LangStandard"
                  Value         "2"
                  Show          off
                }
                Parameter {
                  Variable      "GnuExtensions"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "RuntimeCheck"
                  Value         "1"
                  Show          off
                }
                Parameter {
                  Variable      "HighlightLevel"
                  Value         "0"
                  Show          off
                }
                Parameter {
                  Variable      "Declarations"
                  Value         "#include <stdlib.h>\n"
"#include <float.h>\n"
"#include <math.h>\n"
"\n"
"#define FREQUENCY\t\tParamRealData(0, 0)\n"
"#define OFFSET\t\t\tParamRealData(1, 0)\n"
"#define INPUT_MIN\t\tParamRealData(2, 0)\n"
"#define INPUT_MAX\t\tParamRealData(2, 1)\n"
"#define OUTPUT_OFF\tParamRealData(3, 0)\n"
"#define OUTPUT_ON\t\tParamRealData(3, 1)\n"
"#define UPDATE_PEAK\tParamRealData(4, 0)\n"
"\n"
"#define MOD_IDX(i)\tDiscState(i)\n"
"\n"
"static int WIDTH;\n"
"static double time_stamp;\n"
                  Show          off
                }
                Parameter {
                  Variable      "StartFcn"
                  Value         "WIDTH = NumInputSignals(0);\n"
"\n"
"NextSampleHit = CurrentTime;\n"
"time_stamp = CurrentTime - fmod(1.-OFFSET, 1.)/FREQUENCY;\n"
"for (int i = 0; i < WIDTH; i++)\n"
"{\n"
"   OutputSignal(0, i) = OUTPUT_OFF; // reset outputs\n"
"   MOD_IDX(i) = 0.;\n"
"}\n"
                  Show          off
                }
                Parameter {
                  Variable      "OutputFcn"
                  Value         "if (IsSampleHit(0))\n"
"{\n"
"   double next_sample_time = DBL_MAX;\n"
"   time_stamp = CurrentTime;\n"
"\n"
"   for (int i = 0; i < WIDTH; i++)\n"
"   {\n"
"      double sample_time;\n"
"      if (InputSignal(0, i) >= INPUT_MAX)\n"
"      {\n"
"         MOD_IDX(i) = 1.;\n"
"         OutputSignal(0, i) = OUTPUT_ON;\n"
"      }\n"
"      else if (InputSignal(0, i) <= INPUT_MIN)\n"
"      {\n"
"         MOD_IDX(i) = 0.;\n"
"         OutputSignal(0, i) = OUTPUT_OFF;\n"
"      }\n"
"      else\n"
"      {\n"
"      \tif (UPDATE_PEAK == 1)\n"
"      \t{\n"
"         \tMOD_IDX(i) = (InputSignal(0, i)-INPUT_MIN)/(INPUT_MAX-INPUT_MIN);"
"\n"
"         \tsample_time = time_stamp + (1. - MOD_IDX(i))/FREQUENCY/2.;\n"
"         \tif (sample_time <= time_stamp)\n"
"            \tOutputSignal(0, i) = OUTPUT_ON;\n"
"         \telse\n"
"            \tOutputSignal(0, i) = OUTPUT_OFF;\n"
"         \tif (sample_time > time_stamp && \n"
"             \tsample_time < time_stamp+1./FREQUENCY/2. &&\n"
"             \tsample_time < next_sample_time)\n"
"            \tnext_sample_time = sample_time;\n"
"         }\n"
"         else\n"
"         {\n"
"         \tMOD_IDX(i) = (InputSignal(0, i)-INPUT_MIN)/(INPUT_MAX-INPUT_MIN);"
"\n"
"         \tsample_time = time_stamp + MOD_IDX(i)/FREQUENCY/2.;\n"
"         \tif (sample_time <= time_stamp)\n"
"            \tOutputSignal(0, i) = OUTPUT_OFF;\n"
"         \telse\n"
"            \tOutputSignal(0, i) = OUTPUT_ON;\n"
"         \tif (sample_time > time_stamp && \n"
"             \tsample_time < time_stamp+1./FREQUENCY/2. &&\n"
"             \tsample_time < next_sample_time)\n"
"            \tnext_sample_time = sample_time;         \n"
"         }\n"
"      }\n"
"   }\n"
"   NextSampleHit = next_sample_time;\n"
"}\n"
"\n"
"else if (IsSampleHit(1))\n"
"{\n"
"   double next_switching_time = DBL_MAX;\n"
"\n"
"   if (CurrentTime < time_stamp + 1./FREQUENCY/2.)\n"
"   {\n"
"      for (int i = 0; i < WIDTH; i++)\n"
"      {\n"
"         if (MOD_IDX(i) > 0. && MOD_IDX(i) < 1.)\n"
"         {\n"
"            if (UPDATE_PEAK == 1)\n"
"            {\n"
"            \tdouble turn_on_time = time_stamp + (1. - MOD_IDX(i))/FREQUENCY/"
"2.;;\n"
"            \tif (CurrentTime >= turn_on_time)\n"
"               \tOutputSignal(0, i) = OUTPUT_ON;\n"
"            \telse if (turn_on_time < next_switching_time &&\n"
"                     \tturn_on_time < time_stamp + 1./FREQUENCY/2.)\n"
"               \tnext_switching_time = turn_on_time;\n"
"             }\n"
"             else\n"
"             {\n"
"            \tdouble turn_off_time = time_stamp + MOD_IDX(i)/FREQUENCY/2.;;\n"
"            \tif (CurrentTime >= turn_off_time)\n"
"               \tOutputSignal(0, i) = OUTPUT_OFF;\n"
"            \telse if (turn_off_time < next_switching_time &&\n"
"                     \tturn_off_time < time_stamp + 1./FREQUENCY/2.)\n"
"               \tnext_switching_time = turn_off_time;                        "
"  \n"
"             }\n"
"         }\n"
"      }\n"
"   }\n"
"   if (next_switching_time == DBL_MAX)\n"
"   {\n"
"      for (int i = 0; i < WIDTH; i++)\n"
"      {\n"
"         if (MOD_IDX(i) > 0. && MOD_IDX(i) < 1.)\n"
"         {\n"
"            if (UPDATE_PEAK == 1)\n"
"            {\n"
"            \tdouble turn_off_time = time_stamp + (1. + MOD_IDX(i))/FREQUENCY"
"/2.;;\n"
"            \tif (CurrentTime >= turn_off_time)\n"
"            \t   OutputSignal(0, i) = OUTPUT_OFF;\n"
"            \telse if (turn_off_time < next_switching_time && \n"
"            \t         turn_off_time < time_stamp + 1./FREQUENCY)\n"
"             \t  next_switching_time = turn_off_time;\n"
"         \t}\n"
"         \telse\n"
"         \t{\n"
"            \tdouble turn_on_time = time_stamp + (2. - MOD_IDX(i))/FREQUENCY/"
"2.;;\n"
"            \tif (CurrentTime >= turn_on_time)\n"
"            \t   OutputSignal(0, i) = OUTPUT_ON;\n"
"            \telse if (turn_on_time < next_switching_time && \n"
"            \t         turn_on_time < time_stamp + 1./FREQUENCY)\n"
"             \t  next_switching_time = turn_on_time;         \t\n"
"         \t}\n"
"         }\n"
"      }\n"
"   }\n"
"   NextSampleHit = next_switching_time;\n"
"}\n"
                  Show          off
                }
                Parameter {
                  Variable      "UpdateFcn"
                  Value         ""
                  Show          off
                }
                Parameter {
                  Variable      "DerivativeFcn"
                  Value         ""
                  Show          off
                }
