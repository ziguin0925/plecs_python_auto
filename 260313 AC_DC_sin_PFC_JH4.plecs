    Component {
      Type          Subsystem
      Name          "Symmetrical PWM1"
      Show          off
      Position      [1085, 555]
      Direction     up
      Flipped       off
      LabelPosition south
      Frame         [-20, -20; 20, 20]
      SampleTime    "-1"
      CodeGenDiscretizationMethod "2"
      CodeGenTarget "Generic"
      MaskType      "Symmetrical PWM"
      MaskDescription "PWM generator with a symmetrical triangular carrier. If"
" the input is a vector, the output is also a vector of the same width."
      MaskHelp      "qthelp:///symmetricalpwm.html"
      MaskIconFrame on
      MaskIconOpaque off
      MaskIconRotates on
      MaskInit      "if numel(fc)>1 || fc<=0,\n"
"  error('Carrier frequency must be a positive scalar.');\n"
"end\n"
"if numel(carrier_phaseshift)>1 || carrier_phaseshift<0 || carrier_phaseshift>"
"=1,\n"
"  error('Carrier phase shift must be a scalar in the range [0; 1[.');\n"
"end\n"
"\n"
"switch sampling\n"
"  case 1  %%carrier starts at center\n"
"    config = 1;\n"
"    carrier_phaseshift = mod(carrier_phaseshift+.75, 1);\n"
"  case 2  %%carrier starts at max\n"
"    config = 1;\n"
"    %%carrier_phaseshift unchanged\n"
"  case 3  %%double update\n"
"    config = 2;\n"
"  case 4  %%single update at max\n"
"    config = 3;\n"
"    update_peak = 1;\n"
"  case 5  %%single update at min\n"
"    config = 3;\n"
"    update_peak = 0;\n"
"  case 6  %%carrier starts at min\n"
"    config = 1;\n"
"    carrier_phaseshift = mod(carrier_phaseshift+.5, 1);\n"
"  otherwise\n"
"    error('Please choose one of the PWM sampling patterns.')\n"
"end\n"
      Parameter {
        Variable      "sampling"
        Prompt        "Sampling"
        Type          FixedText
        PossibleValues {"Natural (carrier starts at min.)" = 6, "Natural (carr"
"ier starts at center)" = 1, "Natural (carrier starts at max.)" = 2, "Regular "
"(single update at min.)" = 5, "Regular (single update at max.)" = 4, "Regular"
" (double update)" = 3}
        Value         "3"
        Show          off
        Tunable       off
        TabName       ""
      }
      Parameter {
        Variable      "fc"
        Prompt        "Carrier frequency (Hz)"
        Type          FreeText
        Value         "fs"
        Show          off
        Tunable       off
        TabName       ""
      }
      Parameter {
        Variable      "carrier_phaseshift"
        Prompt        "Carrier phase shift (p.u.)"
        Type          FreeText
        Value         "0"
        Show          off
        Tunable       off
        TabName       ""
        Alias         "offset"
      }
      Parameter {
        Variable      "carrier_limits"
        Prompt        "Carrier limits [min max]"
        Type          FreeText
        Value         "[0 1]"
        Show          off
        Tunable       off
        TabName       ""
        Alias         "input_limits"
      }
      Parameter {
        Variable      "output_values"
        Prompt        "Output values [off on]"
        Type          FreeText
        Value         "[ 0 1]"
        Show          off
        Tunable       off
        TabName       ""
      }
