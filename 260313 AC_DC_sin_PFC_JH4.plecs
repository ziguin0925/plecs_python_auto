    Component {
      Type          Subsystem
      Name          "Ede (PLL)"
      Show          on
      Position      [520, 705]
      Direction     up
      Flipped       off
      LabelPosition south
      Frame         [-40, -20; 40, 20]
      SampleTime    "-1"
      CodeGenDiscretizationMethod "2"
      CodeGenTarget "Generic"
      MaskType      "Single-Phase PLL"
      MaskDescription "Configurable PLL in continuous time-domain with two dif"
"ferent phase detection approaches. "
      MaskHelp      "qthelp:///singlephasepll.html"
      MaskDisplay   "local shift = 0\n"
"if Dialog:get('sincos')~='2' then\n"
"   shift = 7\n"
"   Icon:text(0, -13, 'sin/cos')\n"
"end\n"
"Icon:text(0, -5+shift, 'PLL')\n"
"-- Phase symbol\n"
"Icon:line({37, 31, 36}, {-8, -8, -12})\n"
"-- Magnitude symbol\n"
"Icon:line({37, 37}, {-3, 3})\n"
"Icon:circle(34, 0, 0.5)\n"
"Icon:line({31, 31}, {-3, 3})\n"
"-- Frequency text\n"
"if Dialog:get('units') ~= '1' then\n"
"\tIcon:text(34,10,'f')\n"
"else\n"
"\tIcon:text(34,10,'w')\n"
"end\n"
"-- 1-phase symbol\n"
"Icon:text( -4, 5+shift, '1', 'FontSize', 10)\n"
"Icon:circle(4, 5+shift, 3)\n"
"Icon:line({1, 7},{8+shift, 2+shift})\n"
      MaskDisplayLang "2"
      MaskIconFrame on
      MaskIconOpaque off
      MaskIconRotates on
      MaskInit      "if f0 <= 0\n"
"\tplecs('error', 'Error in parameter \"Nominal frequency\": Positive number e"
"xpected.'); return;\n"
"end\n"
"if Vpk < 0\n"
"\tplecs('error', 'Error in parameter \"Nominal input voltage\": Positive numb"
"er expected.'); return;\n"
"end\n"
"if not(isnumeric(kp))\n"
"\tplecs('error', 'Error in parameter \"Proportional gain Kp\": Finite numeric"
"al value expected.'); return;\n"
"end\n"
"if not(isnumeric(ki))\n"
"\tplecs('error', 'Error in parameter \"Integral gain Ki\": Finite numerical v"
"alue expected.'); return;\n"
"end\n"
"if not(isnumeric(kANF))\n"
"\tplecs('error', 'Error in parameter \"ANF gain k\": Finite numerical value e"
"xpected.'); return;\n"
"end\n"
"if not(isnumeric(kSOGI))\n"
"\tplecs('error', 'Error in parameter \"SOGI filter gain k\": Finite numerical"
" value expected.'); return;\n"
"end\n"
"if not(isnumeric(theta0))\n"
"\tplecs('error', 'Error in parameter \"Initial phase-angle\": Finite numerica"
"l value expected.'); return;\n"
"end\n"
"if not(isnumeric(f0))\n"
"\tplecs('error', 'Error in parameter \"Nominal frequency\": Finite numerical "
"value expected.'); return;\n"
"end\n"
"if not(isnumeric(Vpk))\n"
"\tplecs('error', 'Error in parameter \"Nominal input voltage\": Finite numeri"
"cal value expected.'); return;\n"
"end\n"
"\n"
"if units == 1\n"
"\tf0 = f0/(2*pi);\n"
"\tunit = 1;\n"
"elseif units == 2\n"
"\ttheta0 = theta0*2*pi;\n"
"\tunit = 2;\n"
"else\n"
"\ttheta0 = theta0*pi/180;\n"
"\tunit = 2;\n"
"end\n"
"\n"
"Vrms = Vpk / sqrt(2);\n"
"w0 = 2*pi*f0;\n"
"Vnom = Vpk;\n"
"theta0 = mod(theta0, 2*pi);\n"
"if contr_design == 1\n"
"\tKp = 9.2/(3/f0);\n"
"\tTi = (3/f0)*(1/sqrt(2))^2/2.3;\n"
"\tKi = Kp/Ti;\n"
"\tif type == 1\n"
"\t\tk = Kp;\n"
"\t\twf = 2*pi*f0*sqrt(2);\n"
"\telse\n"
"\t\tk = sqrt(2);\n"
"\t\twf = 2*pi*f0*k;\n"
"\tend\n"
"else\n"
"\tKp = kp;\n"
"\tKi = ki;\n"
"\tif type == 1\n"
"\t\tk = kANF;\n"
"\telse\n"
"\t\tk = kSOGI;\n"
"\tend\n"
"end"
      MaskDialogCallback "-- Dispaly Kp and Ki only if Advanced is configured"
"\n"
"if Dialog:get('contr_design') == '2' then\n"
"\tDialog:set('kp','Visible', true)\n"
"\tDialog:set('ki','Visible', true)\n"
"else\n"
"\tDialog:set('kp','Visible', false)\n"
"\tDialog:set('ki','Visible', false)\n"
"end\n"
"-- Display k Editbox only if SOGI and Advanced are configured\n"
"if Dialog:get('type') == '2' and Dialog:get('contr_design') == '2' then\n"
"\tDialog:set('kSOGI','Visible', true)\n"
"else\n"
"\tDialog:set('kSOGI','Visible', false)\n"
"end\n"
"-- Display wf Editbox only if ePLL and Advanced are configured\n"
"if Dialog:get('type') == '1' and Dialog:get('contr_design') == '2' then\n"
"\tDialog:set('kANF','Visible', true)\n"
"else\n"
"\tDialog:set('kANF','Visible', false)\n"
"end\n"
"-- Hide sincos terminal\n"
"Block:showTerminal('sincos', Dialog:get('sincos')~='2')"
      Parameter {
