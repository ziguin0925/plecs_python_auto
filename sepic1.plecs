    Component {
      Type          Subsystem
      Name          "Discrete PID\nController1"
      Show          on
      Position      [415, 830]
      Direction     up
      Flipped       off
      LabelPosition south
      Frame         [-40, -25; 40, 25]
      SampleTime    "-1"
      CodeGenDiscretizationMethod "2"
      CodeGenTarget "Generic"
      MaskType      "Discrete PID Controller"
      MaskDescription "Configurable PID Controller (parallel form) in discrete"
" time-domain with filtered derivative term and two different anti reset-windu"
"p methods.\n"
      MaskHelp      "qthelp:///discretepidcontroller.html"
      MaskDisplay   "local string_type = ''\n"
"local string_domain = ''\n"
"local string_final = ''\n"
"local reset = tonumber(Dialog:get('ex_reset'))\n"
"\n"
"local function drawTrigger(x,y,type)\n"
"\tif type == 1 then\n"
"\t\tIcon:line({x, x}, {y-3, y+3})\n"
"\t\tIcon:line({x, x+2.5}, {y-3, y-3})\n"
"\t\tIcon:line({x, x-2.5}, {y+3, y+3})\t\n"
"\t\tIcon:line({x-2, x}, {y+1, y-1})\n"
"\t\tIcon:line({x+2, x}, {y+1, y-1})\n"
"\telseif type == 2 then\n"
"\t\tIcon:line({x, x}, {y-3, y+3})\n"
"\t\tIcon:line({x, x+2.5}, {y+3, y+3})\n"
"\t\tIcon:line({x, x-2.5}, {y-3, y-3})\t\n"
"\t\tIcon:line({x-2, x}, {y-1, y+1})\n"
"\t\tIcon:line({x+2, x}, {y-1, y+1})\n"
"\telseif type == 3 then\n"
"\t\tIcon:line({x-4.5, x-2, x-2, x+2, x+2, x+4.5},\n"
"\t\t          {y+3, y+3, y-3, y-3, y+3, y+3})\n"
"\t\tIcon:line({x-4, x-2, x}, {y+1.5, y-1, y+1.5})\n"
"\t\tIcon:line({x, x+2, x+4}, {y-1.5, y+1, y-1.5})\n"
"\telse\t\t\n"
"\t\tIcon:line({x-2.5, x-1, x-1, x+2, x+2, x+3.5},\n"
"\t\t     \t\t {y+3, y+3, y-3, y-3, y+3, y+3})\n"
"\tend\n"
"end\n"
"\n"
"local function drawSaturation(x,y)\n"
"\tIcon:line({x+2, x-2}, {y-5, y+5})\n"
"\tIcon:line({x+2, x+5}, {y-5, y-5})\n"
"\tIcon:line({x-5, x-2}, {y+5, y+5})\n"
"end\n"
"\n"
"if reset ~= 1 then\n"
"\tdrawTrigger(-35, 10, reset-1)\n"
"end\n"
"\n"
"if tonumber(Dialog:get('sat_lim')) == 2 and tonumber(Dialog:get('ex_sat')) =="
" 1  then\n"
"\tdrawSaturation(-16, -15)\n"
"end\n"
"\n"
"if Dialog:get('cont_type') == '1' then\n"
"\tstring_type = 'P'\n"
"elseif Dialog:get('cont_type') == '2' then\n"
"\tstring_type = 'I'\n"
"elseif Dialog:get('cont_type') == '3' then\n"
"\tstring_type = 'PI'\n"
"elseif Dialog:get('cont_type') == '4' then\n"
"\tstring_type = 'PD'\n"
"elseif Dialog:get('cont_type') == '5' then\n"
"\tstring_type = 'PID'\n"
"end\n"
"string_domain = '(z)'\n"
"\n"
"string_final = string_type .. string_domain\n"
"Icon:text(string_final)\n"
      MaskDisplayLang "2"
      MaskIconFrame on
      MaskIconOpaque off
      MaskIconRotates on
      MaskInit      "if not(isnumeric(kp))\n"
"\terror('Error in parameter \"Proportional gain Kp\": Finite numerical value "
"expected.')\n"
"end\n"
"\n"
"if not(isnumeric(ki))\n"
"\terror('Error in parameter \"Integral gain Ki\": Finite numerical value expe"
"cted.')\n"
"end\n"
"\n"
"if not(isnumeric(kd))\n"
"\terror('Error in parameter \"Derivative gain Kd\": Finite numerical value ex"
"pected.')\n"
"end\n"
"\n"
"if not(isnumeric(kf))\n"
"\terror('Error in parameter \"Filter Coefficient Kf\": Finite numerical value"
" expected.')\n"
"end\n"
"\n"
"if not(isnumeric(kbc))\n"
"\terror('Error in parameter \"Back-calculation gain\": Finite numerical value"
" expected.')\n"
"end\n"
"\n"
"if (not(isnumeric(t_sample)) || (t_sample <= 0 && t_sample ~= -1))\n"
"\tif (cont_type >= 4 && int_method ~= 1)\n"
"\t\terror('Error in parameter \"Sample time\": Not a discrete sample time.') "
"\n"
"\telse\n"
"\t\terror('Error in parameter \"Sample time\": Not a discrete or inherited sa"
"mple time.')\n"
"\tend\n"
"end\n"
"\n"
"if (cont_type >= 4 && t_sample == -1)\n"
"\tif (int_method == 2)\n"
"\t\terror('Error in parameter \"Sample time\": Inherited sample time not allo"
"wed for a controller with active D part (PD, PID) and Backward Euler integrat"
"ion method. Consider using a Forward Euler integration method.')\n"
"\telseif (int_method == 3)\n"
"\t\terror('Error in parameter \"Sample time\": Inherited sample time not allo"
"wed for a controller with active D part (PD, PID) and Trapezoidal integration"
" method. Consider using a Forward Euler integration method.')\n"
"\tend\n"
"end\n"
"\n"
"if not(isnumeric(low_limit))\n"
"\terror('Error in parameter \"Lower saturation limit\": Scalar numerical valu"
"e expected.')\n"
"end\n"
"\n"
"if not(isnumeric(up_limit))\n"
"\terror('Error in parameter \"Upper saturation limit\": Scalar numerical valu"
"e expected.')\n"
"end\n"
"\n"
"if (cont_type == 2 || cont_type == 3 || cont_type == 5)\n"
"\tki_enable = 2;\n"
"else\n"
"\tki_enable = 1;\n"
"end\n"
"\n"
"if (cont_type == 4 || cont_type == 5)\n"
"\tkd_enable = 2;\n"
"else\n"
"\tkd_enable = 1;\n"
"end\n"
"\n"
"if cont_type == 1\n"
"\tki = 0.0;\n"
"\tkd = 0.0;\n"
"\tkf = 0.0;\n"
"elseif cont_type == 2\n"
"\tkp = 0.0;\n"
"\tkd = 0.0;\n"
"\tkf = 0.0;\n"
"elseif cont_type == 3\n"
"\tkd = 0.0;\n"
"\tkf = 0.0;\n"
"elseif cont_type == 4\n"
"\tki = 0.0;\n"
"end\n"
"if ex_reset == 5\n"
"\ttrigger_type = 2;\n"
"else\n"
"\ttrigger_type = 1;\n"
"end\n"
      MaskDialogCallback "if Dialog:get('par_source') == '2' then\n"
"\tDialog:set('kp','Visible', false)\n"
"\tDialog:set('ki','Visible', false)\n"
"\tDialog:set('kd','Visible', false)\n"
"\tDialog:set('kf','Visible', false)\n"
"\tDialog:set('kbc','Visible', false)\n"
"\tif Dialog:get('cont_type') == '1' then\n"
"\t\tBlock:showTerminal('Kp', true)\n"
"\t\tBlock:showTerminal('Ki', false)\n"
"\t\tBlock:showTerminal('Kd', false)\n"
"\t\tBlock:showTerminal('Kf', false)\n"
"\t\tBlock:showTerminal('Kbc', false)\n"
"\telseif Dialog:get('cont_type') == '2' then\n"
"\t\tBlock:showTerminal('Ki', true)\n"
"\t\tBlock:showTerminal('Kbc', true)\n"
"\t\tBlock:showTerminal('Kp', false)\n"
"\t\tBlock:showTerminal('Kd', false)\n"
"\t\tBlock:showTerminal('Kf', false)\n"
"\telseif Dialog:get('cont_type') == '3' then\n"
"\t\tBlock:showTerminal('Kp', true)\n"
"\t\tBlock:showTerminal('Ki', true)\n"
"\t\tBlock:showTerminal('Kbc', true)\n"
"\t\tBlock:showTerminal('Kd', false)\n"
"\t\tBlock:showTerminal('Kf', false)\n"
"\telseif Dialog:get('cont_type') == '4' then\n"
"\t\tBlock:showTerminal('Kp', true)\n"
"\t\tBlock:showTerminal('Kd', true)\n"
"\t\tBlock:showTerminal('Kf', true)\n"
"\t\tBlock:showTerminal('Ki', false)\n"
"\t\tBlock:showTerminal('Kbc', false)\n"
"\telseif Dialog:get('cont_type') == '5' then\n"
"\t\tBlock:showTerminal('Kp', true)\n"
"\t\tBlock:showTerminal('Ki', true)\n"
"\t\tBlock:showTerminal('Kd', true)\n"
"\t\tBlock:showTerminal('Kf', true)\n"
"\t\tBlock:showTerminal('Kbc', true)\n"
"\tend\n"
"else\n"
"\tBlock:showTerminal('Kp', false)\n"
"\tBlock:showTerminal('Ki', false)\n"
"\tBlock:showTerminal('Kd', false)\n"
"\tBlock:showTerminal('Kf', false)\n"
"\tBlock:showTerminal('Kbc', false)\n"
"\tif Dialog:get('cont_type') == '1' then\n"
"\t\tDialog:set('kp','Visible', true)\n"
"\t\tDialog:set('ki','Visible', false)\n"
"\t\tDialog:set('kd','Visible', false)\n"
"\t\tDialog:set('kf','Visible', false)\n"
"\t\tDialog:set('kbc','Visible', false)\n"
"\telseif Dialog:get('cont_type') == '2' then\n"
"\t\tDialog:set('ki','Visible', true)\n"
"\t\tDialog:set('kbc','Visible', true)\n"
"\t\tDialog:set('kp','Visible', false)\n"
"\t\tDialog:set('kd','Visible', false)\n"
"\t\tDialog:set('kf','Visible', false)\n"
"\telseif Dialog:get('cont_type') == '3' then\n"
"\t\tDialog:set('kp','Visible', true)\t\n"
"\t\tDialog:set('ki','Visible', true)\n"
"\t\tDialog:set('kbc','Visible', true)\n"
"\t\tDialog:set('kd','Visible', false)\n"
"\t\tDialog:set('kf','Visible', false)\n"
"\telseif Dialog:get('cont_type') == '4' then\n"
"\t\tDialog:set('kp','Visible', true)\n"
"\t\tDialog:set('kd','Visible', true)\n"
"\t\tDialog:set('kf','Visible', true)\n"
"\t\tDialog:set('ki','Visible', false)\n"
"\t\tDialog:set('kbc','Visible', false)\n"
"\telseif Dialog:get('cont_type') == '5' then\n"
"\t\tDialog:set('kp','Visible', true)\n"
"\t\tDialog:set('ki','Visible', true)\n"
"\t\tDialog:set('kd','Visible', true)\n"
"\t\tDialog:set('kf','Visible', true)\n"
"\t\tDialog:set('kbc','Visible', true)\n"
"\tend\n"
"end\n"
"\n"
"if Dialog:get('aw_method')=='2' then\n"
"\tif Dialog:get('par_source')~='2' then\n"
"\t\tDialog:set('kbc','Visible', true)\n"
"\telse\n"
"\t\tDialog:set('kbc','Visible', false)\n"
"\tend\n"
"else\n"
"\tDialog:set('kbc','Visible', false)\n"
"\tBlock:showTerminal('Kbc', false)\n"
"end\n"
"Block:showTerminal('reset', Dialog:get('ex_reset')~='1')\n"
"Block:showTerminal('x0',Dialog:get('x0_source')~='1')\n"
"Dialog:set('x0','Visible', Dialog:get('x0_source')=='1')\n"
"if Dialog:get('ex_reset')~='1' then\n"
"\tBlock:moveTerminal('reset', -40, 10)\n"
"end\n"
"\n"
"if Dialog:get('ex_sat') == '2' then\n"
"\tDialog:set('sat_lim','Visible',false)\n"
"\tDialog:set('up_limit','Visible',false)\n"
"\tDialog:set('low_limit','Visible',false)\n"
"\tBlock:showTerminal('max', false)\n"
"\tBlock:showTerminal('min', false)\n"
"\tBlock:showTerminal('u*', Dialog:get('aw_method')~='1')\n"
"\tif Dialog:get('aw_method')~='1' then\n"
"\t\tBlock:moveTerminal('u*', -40, -15)\n"
"\tend\n"
"else\n"
"\tBlock:showTerminal('u*', false)\t\n"
"\tDialog:set('sat_lim','Visible',true)\n"
"\tif Dialog:get('sat_lim') == '2' then\n"
"\t\tDialog:set('up_limit','Visible',false)\n"
"\t\tDialog:set('low_limit','Visible',false)\n"
"\t\tBlock:showTerminal('max', true)\n"
"\t\tBlock:showTerminal('min', true)\n"
"\telse\n"
"\t\tDialog:set('up_limit','Visible',true)\n"
"\t\tDialog:set('low_limit','Visible',true)\n"
"\t\tBlock:showTerminal('max', false)\n"
"\t\tBlock:showTerminal('min', false)\n"
"\tend\n"
"end\n"
"\t\n"
"\t"
      Parameter {
        Variable      "cont_type"
        Prompt        "Controller type"
        Type          FixedText
        PossibleValues {"P", "I", "PI", "PD", "PID"}
        Value         "3"
        Show          off
        Tunable       off
        TabName       "Basic"
      }
      Parameter {
        Variable      "par_source"
        Prompt        "Parameter source"
        Type          FixedText
        PossibleValues {"internal", "external"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Basic"
      }
      Parameter {
        Variable      "kp"
        Prompt        "Proportional gain Kp"
        Type          FreeText
        Value         "0.01"
        Show          off
        Tunable       on
        TabName       "Basic"
      }
      Parameter {
        Variable      "ki"
        Prompt        "Integral gain Ki"
        Type          FreeText
        Value         "1"
        Show          off
        Tunable       on
        TabName       "Basic"
      }
      Parameter {
        Variable      "kd"
        Prompt        "Derivative gain Kd"
        Type          FreeText
        Value         "1"
        Show          off
        Tunable       on
        TabName       "Basic"
      }
      Parameter {
        Variable      "kf"
        Prompt        "Derivative filter coefficient Kf"
        Type          FreeText
        Value         "1"
        Show          off
        Tunable       on
        TabName       "Basic"
      }
      Parameter {
        Variable      "ex_reset"
        Prompt        "External reset"
        Type          FixedText
        PossibleValues {"none", "rising", "falling", "either", "level"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Basic"
      }
      Parameter {
        Variable      "x0_source"
        Prompt        "Initial condition source"
        Type          FixedText
        PossibleValues {"internal", "external"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Basic"
      }
      Parameter {
        Variable      "x0"
        Prompt        "Initial condition"
        Type          FreeText
        Value         "0"
        Show          off
        Tunable       off
        TabName       "Basic"
      }
      Parameter {
        Variable      "ex_sat"
        Prompt        "Saturation"
        Type          FixedText
        PossibleValues {"internal", "external"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Anti-Windup"
      }
      Parameter {
        Variable      "sat_lim"
        Prompt        "Saturation limits"
        Type          FixedText
        PossibleValues {"constant", "variable"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Anti-Windup"
      }
      Parameter {
        Variable      "int_method"
        Prompt        "Integration method"
        Type          FixedText
        PossibleValues {"Forward Euler", "Backward Euler", "Trapezoidal"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Discrete-time settings"
      }
      Parameter {
        Variable      "t_sample"
        Prompt        "Sample time (s)"
        Type          FreeText
        Value         "1e-5"
        Show          off
        Tunable       off
        TabName       "Discrete-time settings"
      }
      Parameter {
        Variable      "up_limit"
        Prompt        "Upper saturation limit"
        Type          FreeText
        Value         "inf"
        Show          off
        Tunable       off
        TabName       "Anti-Windup"
      }
      Parameter {
        Variable      "low_limit"
        Prompt        "Lower saturation limit"
        Type          FreeText
        Value         "-inf"
        Show          off
        Tunable       off
        TabName       "Anti-Windup"
      }
      Parameter {
        Variable      "aw_method"
        Prompt        "Anti-windup method"
        Type          FixedText
        PossibleValues {"none", "Back-Calculation", "Conditional Integration"}
        Value         "1"
        Show          off
        Tunable       off
        TabName       "Anti-Windup"
      }
      Parameter {
        Variable      "kbc"
        Prompt        "Back-calculation gain"
        Type          FreeText
        Value         "1"
        Show          off
        Tunable       on
        TabName       "Anti-Windup"
      }
